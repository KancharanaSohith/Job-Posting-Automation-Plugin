# Server
PORT=3000
NODE_ENV=development

# Database (SQLite for MVP)
DATABASE_URL="file:./data/job-posting.db"

# Organization config
ORG_REQUIRE_HR_APPROVAL=true
ORG_ARCHIVE_DRAFT_DAYS=30

# Company portal adapter: mock | http
PORTAL_ADAPTER=mock
PORTAL_BASE_URL=https://careers.example.com

# Notification adapter: console | teams | slack | outlook
NOTIFICATION_ADAPTER=console
NOTIFICATION_CHANNEL_ID=

# LinkedIn adapter: manual | api
LINKEDIN_ADAPTER=manual
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Teams bot (optional — for future Teams integration)
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=
